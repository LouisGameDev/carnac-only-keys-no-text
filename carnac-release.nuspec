<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
  <metadata>
    <id>carnac</id>
    <title>carnac</title>
    <version>2.4.0</version>
    <authors>Code52</authors>
    <owners>Carnac contributors</owners>
    <summary>A keyboard utility for all your Windows presentation needs</summary>
    <description>Carnac displays what you're typing in a modal as you type it.</description>
    <copyright>Copyright (c) Carnac contributors</copyright>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
  </metadata>
  <files>
    <file src="Carnac.exe" target="lib/net45" />
    <file src="Carnac.exe.config" target="lib/net45" />
  </files>
</package>
